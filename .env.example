# Firebase Configuration
# Copiez ce fichier en .env.local et remplissez avec vos vraies valeurs Firebase
# Trouvez ces valeurs dans : Firebase Console > Project Settings > Your apps > SDK setup

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cloudinary — upload non signé (safe pour le frontend, jamais l'API Secret !)
# Créer un Upload Preset "Unsigned" dans Settings > Upload > Upload presets
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name
